# Required for Next.js API image generation
GOOGLE_API_KEY=

# Required for Python RAG retrieval pipeline
BROWSERBASE_API_KEY=
TAVILY_API_KEY=

# Optional: override Google Maps Static/Street View key
# Defaults to GOOGLE_API_KEY when unset
GOOGLE_MAPS_API_KEY=

# Optional: override Python interpreter used when running main-rag.py locally
RAG_PYTHON_BIN=

# Optional: when set, /api/rag/prepare calls Modal instead of local Python
# Leave unset for local dev (spawns main-rag.py). Set for Vercel/deploy.
MODAL_RAG_PREPARE_URL=
